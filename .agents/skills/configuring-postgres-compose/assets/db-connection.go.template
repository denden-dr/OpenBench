package database

import (
	"context"
	"database/sql"
	"fmt"
	"log"
	"time"
	"github.com/jmoiron/sqlx"
	_ "github.com/jackc/pgx/v5/stdlib"
)

type Config struct {
	Host            string
	Port            string
	User            string
	Password        string
	DBName          string
	SSLMode         string
	MaxOpenConns    int
	MaxIdleConns    int
	ConnMaxLifetime time.Duration
	ConnMaxIdleTime time.Duration
}

type Database struct {
	DB *sqlx.DB
}

func NewConnection(cfg *Config) (*Database, error) {
	dsn := fmt.Sprintf("postgres://%s:%s@%s:%s/%s?sslmode=%s",
		cfg.User, cfg.Password, cfg.Host, cfg.Port, cfg.DBName, cfg.SSLMode)

	// Apply safe pool limits if not configured
	if cfg.MaxOpenConns <= 0 { cfg.MaxOpenConns = 25 }
	if cfg.MaxIdleConns <= 0 { cfg.MaxIdleConns = 5 }

	var db *sqlx.DB
	var err error

	// Retry loop for establishing connection
	for i := 0; i < 5; i++ {
		db, err = sqlx.Open("pgx", dsn)
		if err == nil {
			db.SetMaxOpenConns(cfg.MaxOpenConns)
			db.SetMaxIdleConns(cfg.MaxIdleConns)

			// Use individual timeout contexts for each ping attempt
			pingCtx, pingCancel := context.WithTimeout(context.Background(), 2*time.Second)
			err = db.PingContext(pingCtx)
			pingCancel()

			if err == nil {
				return &Database{DB: db}, nil
			}
			db.Close()
		}
		time.Sleep(2 * time.Second)
	}
	return nil, err
}

func (db *Database) Stats() sql.DBStats {
	return db.DB.Stats()
}
