package auth

import (
	"github.com/gofiber/fiber/v2"
)

// Handler holds dependencies for HTTP handlers
type Handler struct {
	svc   Service
	isDev bool
}

// NewHandler creates a new Handler instance
func NewHandler(svc Service, isDev bool) *Handler {
	return &Handler{svc: svc, isDev: isDev}
}

// Refresh handles token rotation HTTP requests
func (h *Handler) Refresh(c *fiber.Ctx) error {
	rawToken := c.Cookies("refresh_token")
	if rawToken == "" {
		return c.Status(fiber.StatusUnauthorized).JSON(fiber.Map{
			"error": "Refresh token required",
		})
	}

	newRawToken, err := h.svc.RotateRefreshToken(c.UserContext(), rawToken)
	if err != nil {
		return c.Status(fiber.StatusUnauthorized).JSON(fiber.Map{
			"error": err.Error(),
		})
	}

	// ... set cookies, response code mapping ...
	return c.Status(fiber.StatusOK).JSON(fiber.Map{
		"message": "Successfully refreshed session",
	})
}
