package auth

import (
	"context"
	"errors"
	"github.com/denden-dr/openbench/apps/backend/internal/database"
)

// Service defines the auth business logic operations
type Service interface {
	RotateRefreshToken(ctx context.Context, rawToken string) (string, error)
}

type authService struct {
	db        *database.Database
	tokenRepo TokenRepository
}

// NewAuthService returns the Service interface instead of a concrete struct pointer
func NewAuthService(db *database.Database, tokenRepo TokenRepository) Service {
	return &authService{db: db, tokenRepo: tokenRepo}
}

func (s *authService) RotateRefreshToken(ctx context.Context, rawToken string) (string, error) {
	tx, err := s.db.DB.BeginTxx(ctx, nil)
	if err != nil {
		return "", err
	}
	defer tx.Rollback()

	hashedToken := HashSha256(rawToken)
	token, err := s.tokenRepo.GetByHashWithLock(ctx, tx, hashedToken)
	if err != nil {
		return "", errors.New("invalid token")
	}

	if token.IsRevoked {
		return "", errors.New("revoked session")
	}

	if token.IsUsed {
		// Business Logic: Breach remediation
		_ = s.tokenRepo.RevokeFamily(ctx, tx, token.FamilyID)
		_ = tx.Commit()
		return "", errors.New("compromise detected")
	}

	// ... business logic, update old token status, create successor ...
	
	err = tx.Commit()
	return newRawToken, err
}
