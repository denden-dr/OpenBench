# Application Settings
APP_ENV=development
APP_NAME=OpenBench API
PORT=3000

# Database Settings
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=openbench
DB_SSLMODE=disable
DB_MAX_CONNS=25
DB_MIN_CONNS=5
DB_MAX_RETRIES=5
DB_RETRY_BASE_DELAY=1s
DB_RETRY_MAX_DELAY=30s
DB_MAX_CONN_LIFETIME=5m
DB_MAX_CONN_IDLE_TIME=1m

# JWT Auth Settings
JWT_ACCESS_SECRET=your_super_secret_access_key_12345
JWT_REFRESH_SECRET=your_super_secret_refresh_key_54321
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=168h
