# Application Settings
APP_ENV=development
APP_NAME=OpenBench API
PORT=3000

# Database Settings
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=openbench
DB_SSLMODE=disable
DB_MAX_CONNS=25
