# No environment variables are required for default local development.
# The API routes are proxied / routed relative to the server origin.

# Runtime API proxy target used by the SvelteKit node server.
# BACKEND_URL=http://localhost:3000

# Public frontend origin used by SvelteKit adapter-node and CSRF checks.
# ORIGIN=http://localhost:5173

# Comma-separated browser origins allowed to send mutation requests to /api proxy routes.
# CSRF_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
