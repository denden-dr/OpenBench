{
  "app": {
    "env": "development",
    "name": "OpenBench API",
    "port": "3000"
  },
  "db": {
    "host": "localhost",
    "port": "5432",
    "user": "postgres",
    "name": "openbench",
    "sslmode": "disable",
    "max_conns": 25,
    "min_conns": 5,
    "max_retries": 5,
    "retry_base_delay": "1s",
    "retry_max_delay": "30s",
    "max_conn_lifetime": "5m",
    "max_conn_idle_time": "1m"
  },
  "auth": {
    "access_expiry": "15m",
    "refresh_expiry": "168h"
  }
}
