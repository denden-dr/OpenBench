# App Configuration
PORT=8081
APP_ENV=test
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173

# Database Configuration
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=test_password
DB_NAME=openbench_test_db
DB_SSLMODE=disable

# Database Pool Settings (TD-004)
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=2
DB_CONN_MAX_LIFETIME=10m
DB_CONN_MAX_IDLE_TIME=5m

# Database Retry Settings (BE-002)
DB_RETRY_COUNT=3
DB_RETRY_DELAY=500ms
DB_PING_TIMEOUT=1s
