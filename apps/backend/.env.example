# App Configuration
PORT=8080
APP_ENV=development
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=openbench_user
DB_PASSWORD=openbench_secure_password
DB_NAME=openbench_db
DB_SSLMODE=disable

# Database Pool Settings (TD-004)
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=30m
DB_CONN_MAX_IDLE_TIME=15m

# Database Retry Settings (BE-002)
DB_RETRY_COUNT=5
DB_RETRY_DELAY=2s
DB_PING_TIMEOUT=2s

# JWT Configuration
JWT_SECRET=change_me_to_a_secure_random_string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

